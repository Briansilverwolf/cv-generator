[Unit]
Description=FastAPI Container
After=docker.service
Requires=docker.service

[Service]
Restart=always

ExecStartPre=-/usr/bin/docker rm -f fastapi-app

ExecStart=/usr/bin/docker run \
    --name fastapi-app \
    --env-file /etc/cv-api.env \
    -p 8000:8000 \
    silverool/fastapi-app:latest

ExecStop=/usr/bin/docker stop fastapi-app

[Install]
WantedBy=multi-user.target